# Copy to local.properties (same folder as this file) and adjust for your machine.
# Gradle merges these with Android Studio's own local.properties entries.
#
# Android SDK (required):
# sdk.dir=C\:\\Users\\YourName\\AppData\\Local\\Android\\Sdk
#
# Workshop 7 API (optional). Default is the deployed API:
# api.base.url=https://peelin-good-kdeft.ondigitalocean.app/
#
# Stripe publishable key (required for payments). Find yours at:
# https://dashboard.stripe.com/test/apikeys
# stripe.publishable.key=pk_test_...
