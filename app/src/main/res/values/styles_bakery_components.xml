<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Matches register / browse cards: white surface, rounded corners, light stroke -->
    <style name="Widget.Workshop6.Card.Panel" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bakery_card_white</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">3dp</item>
        <item name="strokeColor">@color/bakery_divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Primary CTA: same as register / featured product -->
    <style name="Widget.Workshop6.Button.PrimaryGold" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">@color/bakery_text_light</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="backgroundTint">@color/bakery_gold</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.Workshop6.Button.SecondaryOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/bakery_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="strokeColor">@color/bakery_divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">16dp</item>
    </style>
</resources>
