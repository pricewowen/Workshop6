<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- BACK BUTTON -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="75dp"
            android:layout_height="wrap_content"
            android:text="@string/btn_back" />

        <!-- PRODUCT IMAGE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="240dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp">

            <ImageView
                android:id="@+id/ivProductImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/selected_product_image"/>
        </com.google.android.material.card.MaterialCardView>


        <!-- PRODUCT NAME -->
        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_selected_product_name"
            android:textColor="@color/bakery_text_dark"
            android:textSize="22sp"
            android:textStyle="bold" />


        <!-- PRODUCT PRICE -->
        <TextView
            android:id="@+id/tvProductPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_selected_product_price"
            android:textColor="@color/bakery_gold"
            android:textSize="18sp"
            android:textStyle="bold" />


        <!-- PRODUCT DESCRIPTION -->
        <TextView
            android:id="@+id/tvProductDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_selected_product_description"
            android:textColor="#666666"
            android:textSize="14sp" />


        <!-- REVIEWS TITLE -->
        <TextView
            android:id="@+id/tvReviewsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Customer Reviews"
            android:textColor="@color/bakery_text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />


        <!-- REVIEWS LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvReviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"/>


        <!-- QUANTITY SELECTOR CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/bakery_card_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_product_quantity"
                    android:textColor="@color/bakery_text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDecrease"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="@string/btn_decrease"
                    android:textSize="18sp"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/bakery_gold_bright"
                    android:textColor="@android:color/black" />

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/label_product_quantity_number"
                    android:textColor="@color/bakery_text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIncrease"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="@string/btn_increase"
                    android:textSize="18sp"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/bakery_gold_bright"
                    android:textColor="@android:color/black" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- ADD TO CART BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddToCart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/btn_add_to_cart"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="@color/bakery_gold_bright"
            app:cornerRadius="20dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>