<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/bakery_card_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_product_thumb"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_hero_bakery"
            android:contentDescription="@string/label_products"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/product_row_thumb_placeholder" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_products"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/bakery_text_dark"/>

            <TextView
                android:id="@+id/tvProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/label_product_price"
                android:textSize="13sp"
                android:textColor="@color/bakery_gold"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_selected_arrow"
            android:textSize="20sp"
            android:textColor="@color/bakery_text_secondary"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
