<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background">

    <ScrollView
        android:id="@+id/me_scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bakery_background"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="20dp">

            <!-- Profile hero -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/bakery_card_white"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/bakery_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <FrameLayout
                        android:id="@+id/fl_me_photo"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:clickable="true"
                        android:clipChildren="false"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:id="@+id/iv_me_photo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/me_avatar_ring"
                            android:clipToOutline="true"
                            android:contentDescription="@string/label_photo"
                            android:elevation="2dp"
                            android:scaleType="centerCrop" />

                        <ImageButton
                            android:id="@+id/btn_me_photo_camera"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="bottom|end"
                            android:layout_marginEnd="2dp"
                            android:layout_marginBottom="2dp"
                            android:background="@drawable/me_photo_camera_chip"
                            android:contentDescription="@string/me_photo_camera_cd"
                            android:elevation="2dp"
                            android:padding="4dp"
                            android:scaleType="centerInside"
                            android:visibility="gone"
                            app:srcCompat="@drawable/ic_me_photo_camera"
                            app:tint="@color/bakery_gold_bright" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_me_role"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:textAllCaps="true"
                            android:textColor="@color/bakery_gold_bright"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            tools:text="Customer" />

                        <TextView
                            android:id="@+id/tv_me_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="serif"
                            android:letterSpacing="-0.02"
                            android:lineSpacingMultiplier="1.05"
                            android:textColor="@color/bakery_text_dark"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="Wyatt Martinez" />

                        <TextView
                            android:id="@+id/tv_me_position"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textColor="@color/bakery_text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="Baker"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/tv_me_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/bakery_gold_bright"
                            android:textSize="14sp"
                            tools:text="email@example.com" />

                        <TextView
                            android:id="@+id/tv_me_bakery"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/bakery_text_secondary"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_me_photo_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/photo_pending_approval"
                            android:textColor="@color/bakery_text_tertiary"
                            android:textSize="11sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_me_photo_error"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/bakery_status_closed"
                            android:textSize="12sp"
                            android:visibility="gone" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Guest call-to-action -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_me_guest_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/bakery_card_white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/bakery_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/me_guest_card_title"
                        android:textColor="@color/bakery_text_dark"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.15"
                        android:text="@string/me_guest_card_body"
                        android:textColor="@color/bakery_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Account hub -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_me_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/bakery_card_white"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/bakery_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="18dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_me_account"
                            app:tint="@color/bakery_gold_bright" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="@string/me_section_account_hub"
                            android:textColor="@color/bakery_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_edit_account"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginTop="4dp"
                        android:minHeight="52dp"
                        android:text="@string/btn_edit_account"
                        android:textAllCaps="false"
                        android:textColor="@color/bakery_text_light"
                        android:textSize="15sp"
                        android:textStyle="normal"
                        android:visibility="gone"
                        app:backgroundTint="@color/bakery_gold"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_me_account"
                        app:iconGravity="textStart"
                        app:iconPadding="14dp"
                        app:iconTint="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_customer_details"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginTop="6dp"
                        android:minHeight="52dp"
                        android:text="@string/btn_your_details"
                        android:textAllCaps="false"
                        android:textColor="@color/bakery_text_light"
                        android:textSize="15sp"
                        android:textStyle="normal"
                        android:visibility="gone"
                        app:backgroundTint="@color/bakery_gold"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_me_id_card"
                        app:iconGravity="textStart"
                        app:iconPadding="14dp"
                        app:iconTint="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_loyalty_rewards"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginTop="6dp"
                        android:minHeight="52dp"
                        android:text="@string/btn_loyalty_rewards"
                        android:textAllCaps="false"
                        android:textColor="@color/bakery_text_light"
                        android:textSize="15sp"
                        android:textStyle="normal"
                        app:backgroundTint="@color/bakery_gold"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_me_star"
                        app:iconGravity="textStart"
                        app:iconPadding="14dp"
                        app:iconTint="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_order_history"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginTop="6dp"
                        android:minHeight="52dp"
                        android:text="@string/order_history"
                        android:textAllCaps="false"
                        android:textColor="@color/bakery_text_light"
                        android:textSize="15sp"
                        android:textStyle="normal"
                        app:backgroundTint="@color/bakery_gold"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_me_receipt"
                        app:iconGravity="textStart"
                        app:iconPadding="14dp"
                        app:iconTint="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taste_preferences"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="8dp"
                        android:minHeight="52dp"
                        android:text="@string/btn_taste_preferences"
                        android:textAllCaps="false"
                        android:textColor="@color/bakery_text_light"
                        android:textSize="15sp"
                        android:textStyle="normal"
                        android:visibility="gone"
                        app:backgroundTint="@color/bakery_gold"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/ic_me_favorite"
                        app:iconGravity="textStart"
                        app:iconPadding="14dp"
                        app:iconTint="@color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_me_employee_discount_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/bakery_card_white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/bakery_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/me_employee_discount_hint_title"
                        android:textColor="@color/bakery_text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/me_employee_discount_hint_body"
                        android:textColor="@color/bakery_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_me_ai_recommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/ai_recommendations_panel"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/ai_recommendations_border"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_me_ai_rec_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/me_ai_recommendations_title"
                            android:textColor="@color/ai_recommendations_title"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/me_ai_zone_label"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:textColor="@color/ai_recommendations_accent"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_me_ai_rec_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/me_ai_recommendations_subtitle"
                            android:textColor="@color/ai_recommendations_body"
                            android:textSize="13sp"
                            android:alpha="0.92" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="168dp"
                            android:layout_marginTop="12dp"
                            android:minHeight="168dp">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_me_recommendations"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:clipToPadding="false"
                                android:overScrollMode="never"
                                android:paddingVertical="4dp"
                                android:visibility="gone" />

                            <ProgressBar
                                android:id="@+id/me_recommendations_loading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:indeterminate="true"
                                android:indeterminateTint="@color/ai_recommendations_accent"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tv_me_recommendations_placeholder"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:gravity="center"
                                android:paddingHorizontal="12dp"
                                android:text="@string/me_recommendations_set_preferences_hint"
                                android:textColor="@color/ai_recommendations_body"
                                android:textSize="14sp"
                                android:alpha="0.88"
                                android:visibility="visible" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/me_ai_recommendations_disclaimer_label"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06"
                                android:textColor="@color/ai_recommendations_title"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center"
                                android:text="@string/me_ai_recommendations_disclaimer_body"
                                android:textColor="@color/ai_recommendations_disclaimer"
                                android:textSize="10sp"
                                android:alpha="0.9"
                                android:lineSpacingMultiplier="1.2" />
                        </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="4dp"
                android:text="@string/btn_logout"
                android:textAllCaps="false"
                android:textColor="@color/bakery_gold_bright"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/bakery_card_white"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_me_logout"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/bakery_gold_bright"
                app:strokeColor="@color/bakery_gold_bright"
                app:strokeWidth="2dp" />

            <TextView
                android:id="@+id/tv_deactivate_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:text="@string/me_deactivate_account"
                android:textColor="@color/bakery_status_closed"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/me_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bakery_background"
        android:clickable="true"
        android:elevation="8dp"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/bakery_gold_bright" />
    </FrameLayout>
</FrameLayout>
