<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background">

    <ScrollView
        android:id="@+id/me_scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/bakery_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_me_photo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/circle_bg_gray"
                    android:clipToOutline="true"
                    android:contentDescription="@string/label_photo"
                    android:padding="0dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person_placeholder" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_me_role"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.03"
                        android:textColor="@color/bakery_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="Customer" />

                    <TextView
                        android:id="@+id/tv_me_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text=""
                        android:textColor="@color/bakery_text_dark"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_me_position"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text=""
                        android:textColor="@color/bakery_text_secondary"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="Baker"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/tv_me_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text=""
                        android:textColor="@color/bakery_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_me_bakery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text=""
                        android:textColor="@color/bakery_text_secondary"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_me_photo_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/photo_pending_approval"
                        android:textColor="@color/bakery_text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_edit_account"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:backgroundTint="@color/bakery_primary"
                android:text="@string/btn_edit_account"
                android:textColor="@color/bakery_text_light" />

            <Button
                android:id="@+id/btn_customer_details"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:backgroundTint="@color/bakery_primary"
                android:text="@string/btn_your_details"
                android:textColor="@color/bakery_text_light" />

            <Button
                android:id="@+id/btn_loyalty_rewards"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/bakery_primary"
                android:text="@string/btn_loyalty_rewards"
                android:textColor="@color/bakery_text_light" />

            <Button
                android:id="@+id/btn_order_history"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/bakery_primary"
                android:text="@string/order_history"
                android:textColor="@color/bakery_text_light" />

            <Button
                android:id="@+id/btn_taste_preferences"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:backgroundTint="@color/bakery_primary"
                android:text="@string/btn_taste_preferences"
                android:textColor="@color/bakery_text_light" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_me_ai_recommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/bakery_card_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_me_ai_rec_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/me_ai_recommendations_title"
                        android:textColor="@color/bakery_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="168dp"
                        android:layout_marginTop="12dp"
                        android:minHeight="168dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_me_recommendations"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clipToPadding="false"
                            android:overScrollMode="never"
                            android:paddingVertical="4dp"
                            android:visibility="gone" />

                        <ProgressBar
                            android:id="@+id/me_recommendations_loading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/bakery_gold_bright"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_me_recommendations_placeholder"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:gravity="center"
                            android:paddingHorizontal="12dp"
                            android:text="@string/me_recommendations_set_preferences_hint"
                            android:textColor="@color/bakery_text_secondary"
                            android:textSize="14sp"
                            android:visibility="visible" />
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="@string/btn_logout"
                android:textColor="@color/bakery_status_closed"
                app:cornerRadius="24dp"
                app:strokeColor="@color/bakery_status_closed" />

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/me_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bakery_background"
        android:clickable="true"
        android:elevation="8dp"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/bakery_gold_bright" />
    </FrameLayout>
</FrameLayout>
