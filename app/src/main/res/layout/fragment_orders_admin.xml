<?xml version="1.0" encoding="utf-8"?>
<!--
  Contributor(s): Samantha
  Main: Samantha - Cart checkout payment and order flow UI layout.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background">

    <LinearLayout
        android:id="@+id/orders_admin_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

    <TextView
        android:id="@+id/tv_orders_admin_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/orders_admin_title"
        android:textAppearance="@style/TextAppearance.Bakery.ReviewSectionTitle"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_orders_admin_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/orders_admin_subtitle"
        android:textAppearance="@style/TextAppearance.Bakery.ReviewSectionEmpty"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_orders_admin_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/orders_admin_none_available"
        android:textAppearance="@style/TextAppearance.Bakery.ReviewSectionEmpty"
        android:visibility="gone"
        android:paddingTop="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_orders_admin"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/orders_admin_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bakery_background"
        android:clickable="true"
        android:elevation="8dp"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/bakery_gold_bright" />
    </FrameLayout>

</FrameLayout>

