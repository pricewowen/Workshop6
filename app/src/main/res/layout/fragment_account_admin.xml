<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/bakery_background">

    <TextView
        android:id="@+id/tv_accounts_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/account_admin_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/bakery_text_dark"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_accounts_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/account_admin_subtitle"
        android:textSize="13sp"
        android:textColor="@color/bakery_text_secondary"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_accounts_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/account_admin_none_available"
        android:textColor="@color/bakery_text_secondary"
        android:textSize="14sp"
        android:visibility="gone"
        android:paddingTop="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_accounts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
