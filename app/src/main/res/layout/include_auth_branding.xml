<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <ImageView
        android:layout_width="132dp"
        android:layout_height="132dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/app_brand"
        android:scaleType="fitCenter"
        android:src="@drawable/bakery_logo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="start"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="1.02"
            android:text="@string/login_tagline_line1"
            android:textColor="@color/login_tagline_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="1.02"
            android:text="@string/login_tagline_line2"
            android:textColor="@color/login_tagline_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="1.02"
            android:text="@string/login_tagline_line3"
            android:textColor="@color/login_tagline_accent"
            android:textSize="26sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
