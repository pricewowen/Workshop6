<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bakery_primary"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_chat_short"
            android:textColor="@color/bakery_text_light"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_chat_inbox_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/chat_inbox_subtitle_staff"
            android:textColor="@color/bakery_nav_icon_inactive"
            android:textSize="13sp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_new_chat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="12dp"
        android:minHeight="48dp"
        android:paddingHorizontal="16dp"
        android:text="@string/chat_new"
        android:textAllCaps="false"
        android:textColor="@color/bakery_text_light"
        app:backgroundTint="@color/bakery_gold_bright"
        app:cornerRadius="24dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_staff_threads"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/text_staff_chat_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_margin="24dp"
        android:text="@string/staff_chat_empty_threads"
        android:textAppearance="@style/TextAppearance.Bakery.ReviewSectionEmpty"
        android:textSize="16sp"
        android:visibility="gone" />

</LinearLayout>