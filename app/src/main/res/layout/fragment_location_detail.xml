<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_detail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bakery_background"
        app:navigationContentDescription="@string/cd_navigate_up"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/bakery_text_dark"
        app:titleTextColor="@color/bakery_text_dark" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/location_detail_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:background="@color/bakery_background"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_hero_bakery">

                <ImageView
                    android:id="@+id/iv_hero"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_hero_image"
                    android:scaleType="centerCrop"
                    android:src="@drawable/location_thumb_placeholder" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_detail_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkable="false"
                        android:clickable="false"
                        android:focusable="false"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        app:chipCornerRadius="14dp"
                        app:chipMinHeight="28dp" />

                    <TextView
                        android:id="@+id/tv_detail_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/bakery_gold_bright"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/bakery_card_white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="@string/location_section_contact"
                            android:textColor="@color/bakery_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_detail_address"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:drawablePadding="10dp"
                            android:gravity="center_vertical"
                            android:textColor="@color/bakery_text_dark"
                            android:textSize="14sp"
                            app:drawableStartCompat="@drawable/ic_location_pin_20" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_detail_phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:drawablePadding="10dp"
                            android:gravity="center_vertical"
                            android:textColor="@color/bakery_text_dark"
                            android:textSize="14sp"
                            app:drawableStartCompat="@drawable/ic_phone_20" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_detail_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:drawablePadding="10dp"
                            android:gravity="center_vertical"
                            android:textColor="@color/bakery_text_dark"
                            android:textSize="14sp"
                            app:drawableStartCompat="@drawable/ic_email_20" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/bakery_card_white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="8dp"
                                app:srcCompat="@drawable/ic_schedule_20" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/location_section_hours"
                                android:textColor="@color/bakery_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_bakery_hours"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_directions"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:text="@string/btn_get_directions"
                        android:textAllCaps="false"
                        android:textColor="@color/bakery_text_light"
                        app:backgroundTint="@color/bakery_gold_bright"
                        app:cornerRadius="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_call"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/btn_call"
                        android:textAllCaps="false"
                        android:textColor="@color/bakery_gold_bright"
                        app:backgroundTint="@color/bakery_card_white"
                        app:cornerRadius="24dp"
                        app:strokeColor="@color/bakery_gold_bright"
                        app:strokeWidth="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/section_available_here"
                    android:textColor="@color/bakery_text_dark"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_available_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/available_here_empty"
                    android:textColor="@color/bakery_text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/available_here_strip_height"
                    android:layout_marginBottom="2dp"
                    android:minHeight="@dimen/available_here_strip_height">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_products_stub"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingVertical="4dp"
                        android:saveEnabled="false"
                        android:visibility="gone" />

                    <ProgressBar
                        android:id="@+id/available_products_loading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/bakery_gold_bright"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_bakery_reviews_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/section_product_reviews"
                    android:textAppearance="@style/TextAppearance.Bakery.ReviewSectionTitle" />

                <TextView
                    android:id="@+id/tv_bakery_reviews_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/review_section_stack_spacing"
                    android:text="@string/product_reviews_none_yet"
                    android:textAppearance="@style/TextAppearance.Bakery.ReviewSectionEmpty"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:id="@+id/hsv_bakery_review_filters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/review_section_stack_spacing"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/row_bakery_review_filters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_bakery_review_filter_all"
                            style="@style/Widget.Bakery.ReviewFilterPill"
                            android:background="@drawable/bg_category_chip_selected"
                            android:text="@string/review_filter_all"
                            android:textColor="@color/bakery_text_light" />

                        <TextView
                            android:id="@+id/tv_bakery_review_filter_verified"
                            style="@style/Widget.Bakery.ReviewFilterPill"
                            android:background="@drawable/bg_category_chip"
                            android:text="@string/review_filter_verified"
                            android:textColor="@color/bakery_text_dark" />

                        <TextView
                            android:id="@+id/tv_bakery_review_filter_purchased"
                            style="@style/Widget.Bakery.ReviewFilterPill"
                            android:background="@drawable/bg_category_chip"
                            android:text="@string/review_filter_purchased"
                            android:textColor="@color/bakery_text_dark" />
                    </LinearLayout>
                </HorizontalScrollView>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/review_horizontal_strip_height"
                    android:layout_marginTop="@dimen/review_section_stack_spacing"
                    android:minHeight="@dimen/review_horizontal_strip_height">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_bakery_reviews"
                        style="@style/Widget.Bakery.ReviewsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone" />
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_leave_bakery_review"
                    style="@style/Widget.Bakery.LeaveReviewButton"
                    android:layout_marginTop="@dimen/review_section_stack_spacing"
                    android:text="@string/btn_leave_review" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/location_detail_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bakery_background"
        android:clickable="true"
        android:elevation="12dp"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/bakery_gold_bright" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
