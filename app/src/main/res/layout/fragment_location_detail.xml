<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_detail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bakery_primary"
        app:titleTextColor="@color/white"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@color/white"
        app:navigationContentDescription="@string/cd_navigate_up" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Image -->
            <ImageView
                android:id="@+id/iv_hero"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="@color/bakery_primary"
                android:contentDescription="@string/cd_hero_image"
                android:src="@android:drawable/ic_menu_gallery" />

            <!-- Info Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Status + Distance -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_detail_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkable="false"
                        android:clickable="false"
                        android:focusable="false"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        app:chipMinHeight="28dp"
                        app:chipCornerRadius="14dp" />

                    <TextView
                        android:id="@+id/tv_detail_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textSize="14sp"
                        android:textColor="@color/bakery_gold_bright"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Address -->
                <TextView
                    android:id="@+id/tv_detail_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/bakery_text_dark"
                    android:drawablePadding="8dp"
                    android:layout_marginBottom="6dp" />

                <!-- Phone -->
                <TextView
                    android:id="@+id/tv_detail_phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/bakery_text_dark"
                    android:layout_marginBottom="6dp" />

                <!-- Email -->
                <TextView
                    android:id="@+id/tv_detail_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/bakery_text_dark"
                    android:layout_marginBottom="6dp" />

                <!-- Hours -->
                <TextView
                    android:id="@+id/tv_detail_hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/bakery_text_dark"
                    android:layout_marginBottom="16dp" />

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="24dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_directions"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/btn_get_directions"
                        android:textColor="@color/bakery_text_dark"
                        app:backgroundTint="@color/bakery_gold_bright"
                        app:cornerRadius="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_call"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/btn_call"
                        android:textColor="@color/bakery_gold_bright"
                        app:strokeColor="@color/bakery_gold_bright"
                        app:cornerRadius="24dp" />

                </LinearLayout>

                <!-- STUB: Available Products -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_available_here"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/bakery_text_dark"
                    android:layout_marginBottom="8dp" />

                <!-- TODO: Mason — replace this horizontal RecyclerView with real product data -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_products_stub"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginBottom="24dp" />

                <!-- STUB: Reviews -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_reviews"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/bakery_text_dark"
                    android:layout_marginBottom="8dp" />

                <!-- TODO: Cantor — replace these hardcoded cards with real review data -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/bakery_card_white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stub_review_1_rating"
                            android:textColor="@color/bakery_gold_bright"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stub_review_1_text"
                            android:textColor="@color/bakery_text_dark"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stub_review_1_author"
                            android:textColor="@color/bakery_text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/bakery_card_white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stub_review_2_rating"
                            android:textColor="@color/bakery_gold_bright"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stub_review_2_text"
                            android:textColor="@color/bakery_text_dark"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stub_review_2_author"
                            android:textColor="@color/bakery_text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
