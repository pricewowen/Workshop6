<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="14dp">

    <TextView
        android:id="@+id/text_customer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/bakery_text_dark"
        android:textStyle="bold"
        android:textSize="16sp"
        android:text="Customer Name" />

    <TextView
        android:id="@+id/text_last_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:text="Last message preview"
        android:textColor="@color/bakery_text_secondary"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/text_thread_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Customer thread • OPEN"
        android:textColor="@color/bakery_gold"
        android:textSize="12sp" />

</LinearLayout>
