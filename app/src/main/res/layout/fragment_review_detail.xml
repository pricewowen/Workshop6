<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_review_detail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bakery_background"
        app:navigationContentDescription="@string/cd_navigate_up"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/bakery_text_dark"
        app:titleTextColor="@color/bakery_text_dark" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RatingBar
                android:id="@+id/ratingBarReviewDetail"
                style="@style/Widget.Bakery.ReviewDetailRatingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:numStars="5"
                android:rating="0"
                android:stepSize="1"
                tools:rating="5" />

            <LinearLayout
                android:id="@+id/llReviewDetailBadges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tvReviewDetailVerified"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_review_badge_verified"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/review_badge_verified_text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="@string/review_badge_verified"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvReviewDetailPurchased"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_review_badge_purchased"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/review_badge_purchased_text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="@string/review_badge_purchased"
                    tools:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvReviewDetailComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:lineSpacingMultiplier="1.28"
                android:textColor="@color/bakery_text_secondary"
                android:textIsSelectable="true"
                android:textSize="18sp"
                tools:text="Great staff and fresh pastries every time we visit." />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
