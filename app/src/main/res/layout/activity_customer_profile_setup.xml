<?xml version="1.0" encoding="utf-8"?>
<!--
  Contributor(s): Owen
  Main: Owen - Core account profile loyalty or admin UI layout.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bakery_background"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/bakery_text_dark"
            app:title="@string/customer_profile_title"
            app:titleTextColor="@color/bakery_text_dark" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:background="@color/bakery_card_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <LinearLayout
                    android:id="@+id/profile_name_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_first_name"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/bakery_text_secondary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="4dp" />
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_first_name"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_first_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_first_name"
                                android:inputType="textPersonName|textNoSuggestions"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginHorizontal="3dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_middle_initial"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/bakery_text_secondary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="4dp" />
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_middle_initial"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_middle_initial"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_middle_initial"
                                android:inputType="textPersonName|textNoSuggestions|textCapCharacters"
                                android:maxLength="1"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_last_name"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/bakery_text_secondary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="4dp" />
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_last_name"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_last_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_last_name"
                                android:inputType="textPersonName|textNoSuggestions"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/guest_email_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hint_email"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/bakery_text_secondary"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_email"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_email"
                            android:imeOptions="actionNext"
                            android:inputType="textEmailAddress|textNoSuggestions" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_phone"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/bakery_text_secondary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="4dp" />
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_phone"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_phone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_phone"
                                android:inputType="phone|textNoSuggestions"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/profile_business_phone_column"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_business_phone"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/bakery_text_secondary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="4dp" />
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_business_phone"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_business_phone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_business_phone"
                                android:inputType="phone|textNoSuggestions"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/profile_address_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_address_line_1"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/bakery_text_secondary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_address1"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_address1"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_address1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_address_line_2"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/bakery_text_secondary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_address2"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_address2"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_address2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress|textNoSuggestions"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_city"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/bakery_text_secondary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_city"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:hintEnabled="false">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_city"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_city"
                        android:inputType="textCapWords|textNoSuggestions"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_province"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/bakery_text_secondary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="4dp" />
                        <Spinner
                            android:id="@+id/spinner_province"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@android:drawable/btn_dropdown"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                        <TextView
                            android:id="@+id/tv_province_error"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:textColor="?attr/colorError"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_postal_zip"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/bakery_text_secondary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="4dp" />
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_postal"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_postal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_postal_code"
                                android:inputType="textCapCharacters|textNoSuggestions"
                                android:imeOptions="actionDone"
                                android:maxLength="10" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/bakery_status_closed"
                    android:textSize="13sp"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"
                    tools:visibility="gone" />

                <TextView
                    android:id="@+id/tv_minimal_contact_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:text="@string/guest_minimal_contact_hint"
                    android:textSize="13sp"
                    android:textColor="@color/bakery_text_secondary"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_save_customer_profile"
                    android:textSize="16sp"
                    android:textStyle="normal"
                    android:textColor="@color/bakery_text_light"
                    app:backgroundTint="@color/bakery_gold"
                    app:cornerRadius="28dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</FrameLayout>
