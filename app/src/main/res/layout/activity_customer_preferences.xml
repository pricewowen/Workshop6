<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bakery_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bakery_background"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/bakery_text_dark"
            app:title="@string/title_taste_preferences"
            app:titleTextColor="@color/bakery_text_dark" />

        <ScrollView
            android:id="@+id/scroll_preferences"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/bakery_card_white"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/container_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp" />
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_preferences"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_margin="16dp"
            android:text="@string/btn_save_preferences"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/bakery_text_light"
            app:backgroundTint="@color/bakery_primary"
            app:cornerRadius="28dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/preferences_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bakery_background"
        android:clickable="true"
        android:elevation="6dp"
        android:focusable="true"
        android:visibility="visible">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/bakery_gold_bright" />
    </FrameLayout>
</FrameLayout>
